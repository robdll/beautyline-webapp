# MongoDB
MONGODB_URI=mongodb://localhost:27017/beautyline

# Local seed (development only)
ENABLE_LOCAL_SEED=false
LOCAL_SEED_ADMIN_EMAIL=admin@beautyline.local
LOCAL_SEED_ADMIN_PASSWORD=Password123!

# JWT Auth
JWT_SECRET=change-me-to-a-random-string
JWT_REFRESH_SECRET=change-me-to-another-random-string

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend (email)
RESEND_API_KEY=re_xxxxxxxxxxxx
CONTACT_FROM_EMAIL=noreply@beautylineprofessional.com
CONTACT_TO_EMAIL=info@beautylineprofessional.com

# Cloudinary (media uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Stripe (payments)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx

